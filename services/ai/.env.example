# CaseLens AI service configuration.
# Copy this file to `.env` (same directory) and fill in your key.
# `.env` is gitignored — your key never gets committed.

# Your OpenAI API key. Leave blank to run heuristic-only (no LLM).
OPENAI_API_KEY=

# Optional: which chat model to use for Ask-the-Case and reports.
OPENAI_MODEL=gpt-4o-mini
