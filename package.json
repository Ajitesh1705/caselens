{
  "name": "caselens",
  "version": "0.1.0",
  "private": true,
  "description": "CaseLens — a Gen-AI digital forensics investigation console",
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "build": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev:gateway": "pnpm --filter @caselens/gateway dev",
    "dev:web": "pnpm --filter @caselens/web dev"
  },
  "engines": {
    "node": ">=20"
  }
}
